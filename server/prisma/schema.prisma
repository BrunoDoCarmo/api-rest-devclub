generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String           @id @default(uuid())
  type      Type_Responsible
  name      String
  size      Size
  cnpj      String?          @unique
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  responsible        Responsible?
  memberships        Memberships[]
  notificationEmails NotificationEmail[]

  @@map("tenant")
}

model Responsible {
  id           String   @id @default(uuid())
  name         String
  cpf          String?  @unique
  cnpj         String?  @unique
  public_place String
  number       String
  neighborhood String
  complement   String?
  cep          String
  city         String
  uf           String
  telephone1   String?
  telephone2   String?
  cell_phone1  String
  cell_phone2  String?
  email        String   @unique
  state        State    @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String @unique

  @@map("responsible")
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String?
  username  String?  @unique
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships        Memberships[]
  emailVerifications EmailVerification[]

  @@map("user")
}

model Memberships {
  id    String   @id @default(uuid())
  name  String
  role  UserRole @default(USER)
  state State    @default(ACTIVE)

  userId String
  user   User   @relation(fields: userId, references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  emailVerified Boolean @default(false)

  @@unique([userId, tenantId])
  @@map("memberships")
}

model EmailVerification {
  id        String                @id @default(uuid())
  email     String                @unique
  tokenHash String
  type      EmailVerificationType
  expiresAt DateTime
  verified  Boolean               @default(false)

  userId String?

  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("emailverification")
}

model NotificationEmail {
  id        String   @id @default(uuid())
  content   String
  read      Boolean  @default(false)
  tenantId  String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

enum Type_Responsible {
  PHYSICAL
  LEGAL
}

enum Size {
  SMALL
  MEDIUM
  LARGE
}

enum UserRole {
  ADMIN
  USER
}

enum EmailVerificationType {
  USER
  RESPONSIBLE
}

enum State {
  ACTIVE
  DISABLED
  DELETED
}
